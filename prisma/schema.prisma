generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tale {
  id            String   @id @default(cuid())
  name          String
  timestamp     String   // Display string like "juil. 3 - 9"
  date          DateTime?
  coordinates   String   @default("[]") // JSON-encoded [number, number][]
  chapters      String   @default("[]") // JSON-encoded Chapter[]
  distanceKm    Int      @default(0)
  elevationGain Int      @default(0)
  kmEffort      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
